// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum EnumSheetType {
  BUDGET
  EXPENSE_FLOW
  INCOME
}

model Plan {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  initialDate Int
  endDate     Int
  Sheet       Sheet[]
}

model Sheet {
  id        Int           @id @default(autoincrement())
  name      String        @unique
  planId    Int
  plan      Plan          @relation(fields: [planId], references: [id])
  sheetType EnumSheetType
  Record    Record[]
  Tag       Tag[]
}

model Tag {
  id      Int      @id @default(autoincrement())
  name    String
  sheetId Int
  sheet   Sheet    @relation(fields: [sheetId], references: [id])
  color   String
  Record  Record[]
}

model Record {
  id       Int     @id @default(autoincrement())
  name     String
  amount   Int
  date     BigInt?
  sheetId  Int
  sheet    Sheet   @relation(fields: [sheetId], references: [id])
  bucketId Int?
  bucket   Bucket? @relation(fields: [bucketId], references: [id])
  tagId    Int?
  tag      Tag?    @relation(fields: [tagId], references: [id])
}

model Bucket {
  id     Int      @id @default(autoincrement())
  name   String
  Record Record[]
}
